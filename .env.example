# ── Olla local development environment ──────────────────────────────────────
# Copy to `.env` (gitignored). Defaults below match docker-compose.yml, so the
# app runs locally with no cloud accounts. Clerk/Stripe/Resend are optional.

# API server
PORT=5000
NODE_ENV=development

# Database — docker-compose Postgres
DATABASE_URL=postgres://olla:olla@localhost:5432/olla

# Object storage — local S3 via MinIO (docker-compose). Set STORAGE_DRIVER=replit
# to use Replit Object Storage in production instead.
STORAGE_DRIVER=s3
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=olla-media
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
# S3_PREFIX=

# Clerk (host/vendor auth). The guest capture→upload→video flow works WITHOUT these.
# For host login, create a free dev instance at https://dashboard.clerk.com and paste keys:
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Stripe (billing) — optional locally. Leave blank to disable billing features.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...   # from `stripe listen --forward-to localhost:5000/api/stripe/webhook`

# Email (Resend) — optional. Without it, emails are logged instead of sent (dry-run).
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=Olla <no-reply@example.com>
